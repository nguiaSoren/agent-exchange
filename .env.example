# Agent Exchange — environment. Copy to `.env` and fill. NEVER commit `.env`.

# ── Band (app.band.ai → create agents → copy each agent's API key, shown once) ──
BAND_BASE_URL=https://app.band.ai/api/v1/agent
BAND_AGENT_A_KEY=             # agent A (your account) — used as the market
BAND_AGENT_B_KEY=             # agent B (your account, SAME owner) — a same-owner specialist
BAND_AGENT_OWNER2_KEY=        # 2nd free account's agent — the cross-owner "agent you don't own"
BAND_OWNER2_TAX_HANDLE=       # that agent's full handle, e.g. @other-org/tax-clause-bot
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ── LLM providers (worker agents + the verifier brain) ──
OPENAI_API_KEY=               # or whichever provider your agents run on
AIMLAPI_API_KEY=              # AI/ML API — frontier workers + verifier;  base: https://api.aimlapi.com/v1
FEATHERLESS_API_KEY=          # DEFERRED until the kickoff $25 credit;     base: https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct   # primary CrewAI/Featherless slot; verify ids at /v1/models (L6). Llama-3.3-70B-Instruct is gated/needs-OAuth.
FEATHERLESS_MODEL_2=mistralai/Mistral-Small-24B-Instruct-2501   # 2nd CrewAI/Featherless slot — a DISTINCT model so Featherless shows variety (verify callable at /v1/models, L6).

# ── x402 / Base Sepolia (TESTNET — no real money, no Coinbase account) ──
EVM_PRIVATE_KEY=              # throwaway buyer wallet; generate fresh; testnet-only
SELLER_PAYTO_ADDRESS=        # worker/seller receiving address (can be a 2nd throwaway wallet)
X402_FACILITATOR_URL=https://x402.org/facilitator   # public testnet facilitator — NO API key
X402_NETWORK=eip155:84532    # Base Sepolia
X402_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # Base Sepolia test USDC (6 decimals, EIP-3009)

# ── Run config ──
SEED=1
METRICS_PATH=./data/traces/jobs.jsonl
